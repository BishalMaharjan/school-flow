generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// --- ENUMS ---

enum UserRole {
  SUPER_ADMIN
  SCHOOL_ADMIN
  TEACHER
  STUDENT
  PARENT
}

enum Status {
  ACTIVE
  INACTIVE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

enum FeeFrequency {
  MONTHLY
  TERMLY
  YEARLY
}

enum InvoiceStatus {
  UNPAID
  PARTIAL
  PAID
}

/// --- MODELS ---

model School {
  id       Int     @id @default(autoincrement())
  name     String
  slug     String  @unique
  email    String
  phone    String
  logo_url String?
  status   Status  @default(ACTIVE)

  // Relations
  users      User[]
  students   Student[]
  teachers   Teacher[]
  classes    Class[]
  attendance Attendance[]
  fees       Fee[]
  invoices   Invoice[]

  @@map("schools")
}

model User {
  id        Int      @id @default(autoincrement())
  school_id Int
  name      String
  email     String   @unique
  password  String
  role      UserRole
  status    Status   @default(ACTIVE)

  // Relations
  school            School       @relation(fields: [school_id], references: [id])
  teachers          Teacher[]
  marked_attendance Attendance[]

  @@map("users")
}

model Student {
  id           Int      @id @default(autoincrement())
  school_id    Int
  admission_no String   @unique
  first_name   String
  last_name    String
  dob          DateTime
  class_id     Int
  section_id   Int // Assuming you'll add a Sections model later
  guardian_id  Int // Links to the user account of the parent

  // Relations
  school     School       @relation(fields: [school_id], references: [id])
  class      Class        @relation(fields: [class_id], references: [id])
  attendance Attendance[]
  invoices   Invoice[]

  @@map("students")
}

model Teacher {
  id        Int    @id @default(autoincrement())
  school_id Int
  user_id   Int
  name      String
  email     String
  phone     String

  // Relations
  school School @relation(fields: [school_id], references: [id])
  user   User   @relation(fields: [user_id], references: [id])

  @@map("teachers")
}

model Class {
  id        Int    @id @default(autoincrement())
  school_id Int
  name      String

  // Relations
  school     School       @relation(fields: [school_id], references: [id])
  students   Student[]
  attendance Attendance[]
  fees       Fee[]

  @@map("classes")
}

model Attendance {
  id         Int              @id @default(autoincrement())
  school_id  Int
  student_id Int
  class_id   Int
  date       DateTime
  status     AttendanceStatus
  marked_by  Int

  // Relations
  school  School  @relation(fields: [school_id], references: [id])
  student Student @relation(fields: [student_id], references: [id])
  class   Class   @relation(fields: [class_id], references: [id])
  marker  User    @relation(fields: [marked_by], references: [id])

  @@map("attendance")
}

model Fee {
  id        Int          @id @default(autoincrement())
  school_id Int
  name      String
  amount    Decimal      @db.Decimal(10, 2)
  class_id  Int
  frequency FeeFrequency

  // Relations
  school   School    @relation(fields: [school_id], references: [id])
  class    Class     @relation(fields: [class_id], references: [id])
  invoices Invoice[]

  @@map("fees")
}

model Invoice {
  id         Int           @id @default(autoincrement())
  school_id  Int
  student_id Int
  fee_id     Int
  amount     Decimal       @db.Decimal(10, 2)
  due_date   DateTime
  status     InvoiceStatus

  // Relations
  school  School  @relation(fields: [school_id], references: [id])
  student Student @relation(fields: [student_id], references: [id])
  fee     Fee     @relation(fields: [fee_id], references: [id])

  @@map("invoices")
}
